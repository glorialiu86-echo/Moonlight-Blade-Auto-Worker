PORT=3000

# Qwen / DashScope official docs:
# https://help.aliyun.com/zh/model-studio/openai-compatible-api
# https://help.aliyun.com/zh/model-studio/qwen-vl-ocr
# https://help.aliyun.com/zh/model-studio/vision/

LLM_PROVIDER=qwen
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_REASONING_MODEL=qwen-plus
LLM_VISION_MODEL=qwen3-vl-plus
LLM_OCR_MODEL=qwen-vl-ocr
LLM_API_KEY=

# Local Ollama example:
# TEXT_LLM_PROVIDER=openai_compatible
# TEXT_LLM_BASE_URL=http://127.0.0.1:11434/v1
# TEXT_LLM_MODEL=qwen2.5:3b
# TEXT_LLM_REASONING_MODEL=qwen2.5:3b
# TEXT_LLM_API_KEY=

LOCAL_ASR_MODEL=medium
LOCAL_ASR_LANGUAGE=zh
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8
LOCAL_ASR_CPU_THREADS=8
LOCAL_ASR_PYTHON=
LOCAL_ASR_MODEL_CACHE_DIR=D:\AIModels\faster-whisper
LOCAL_OCR_PYTHON=
LOCAL_OCR_MAX_IMAGE_SIDE=1600
